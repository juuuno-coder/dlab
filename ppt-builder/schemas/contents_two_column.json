{
  "id": "contents_two_column",
  "name": "목차 (2단 카드형)",
  "description": "6개 섹션을 좌우 2단으로 배치한 목차 슬라이드. 섹션별 로마 숫자, 제목, 페이지 범위, 하위 항목을 표시.",
  "template": "templates/contents_two_column.html",
  "canvas": { "width": 1280, "height": 907 },

  "design_system": {
    "colors": {
      "header_bg": "#002B5B",
      "header_accent": "#C8102E",
      "card_border_navy": "#002B5B",
      "card_border_blue": "#004c8c",
      "card_border_red": "#C8102E",
      "card_border_gray": "#6B7280",
      "num_bg": "#f3f6f9",
      "title_text": "#111111",
      "body_text": "#4B5563",
      "page_text": "#6B7280",
      "footer_bg": "#f3f4f6"
    },
    "typography": {
      "page_title": { "size": 42, "weight": 700, "color": "white" },
      "section_title": { "size": 24, "weight": 700, "color": "#111" },
      "section_pages": { "size": 16, "weight": 500, "color": "#6B7280" },
      "sub_items": { "size": 16, "color": "#4B5563", "line_height": 1.5 },
      "section_num": { "size": 32, "weight": 900, "color": "#002B5B" }
    },
    "layout": {
      "header_height": 120,
      "content_padding": "50px 60px 40px",
      "column_gap": 40,
      "card_gap": 25,
      "card_border_radius": 8,
      "card_border_left": 6,
      "footer_height": 40
    }
  },

  "pptx_mapping": {
    "notes": "PptxGenJS 좌표 (인치 단위, 16:9 = 13.33 x 7.5)",
    "header": {
      "shape": "RECTANGLE",
      "x": 0, "y": 0, "w": 13.33, "h": 0.99,
      "fill": "002B5B"
    },
    "header_title": {
      "x": 0.5, "y": 0.15, "w": 5, "h": 0.7,
      "fontSize": 36, "fontFace": "Noto Sans KR", "bold": true, "color": "FFFFFF"
    },
    "card_template": {
      "num_box": { "w": 0.66, "fill": "f3f6f9" },
      "content_area": { "padding_left": 0.2 },
      "shadow": { "type": "outer", "color": "002B5B", "blur": 6, "offset": 2, "opacity": 0.08 }
    },
    "left_column": { "x": 0.5, "w": 5.9 },
    "right_column": { "x": 6.83, "w": 5.9 },
    "cards_y_start": 1.25,
    "card_gap": 0.2,
    "footer": {
      "shape": "RECTANGLE",
      "x": 0, "y": 7.15, "w": 13.33, "h": 0.35,
      "fill": "f3f4f6"
    }
  },

  "data_schema": {
    "sections": [
      {
        "num": "I",
        "title": "string — 섹션 제목",
        "pages": "string — 페이지 범위 (예: 3-8p)",
        "items": ["string — 하위 항목 목록"],
        "accent": "navy | blue | red | gray",
        "column": "left | right",
        "flex": "number — 상대 크기 비율 (기본 1, 큰 섹션은 1.5)"
      }
    ],
    "page_number": "number"
  },

  "example_data": {
    "sections": [
      { "num": "I", "title": "제안개요", "pages": "3-8p", "items": ["제안 배경 및 목적", "사업 이해 및 추진 방향", "제안 전략 및 행사 추진 목표", "핵심 메시지"], "accent": "navy", "column": "left", "flex": 1 },
      { "num": "II", "title": "제안업체 일반", "pages": "9-13p", "items": ["회사 일반 현황", "주요 수행 실적", "수행 역량 및 강점", "조직 및 인원 현황"], "accent": "navy", "column": "left", "flex": 1 },
      { "num": "III", "title": "사업수행부문", "pages": "14-36p", "items": ["행사 컨셉 및 기본방향", "기념식 기획 (프로그램/타임테이블)", "행사 공간 구성 및 연출 계획", "공연 및 문화 프로그램", "참석자 관리 (DB/셔틀버스)", "홍보 전략 및 디자인 계획", "행사 기록 및 릴레이 영상"], "accent": "blue", "column": "left", "flex": 1.5 },
      { "num": "IV", "title": "사업관리", "pages": "37-44p", "items": ["행사 운영 조직 및 유관기관 협조", "인력 운영 및 VIP 의전 계획", "업무보고 및 위기관리 대응", "종합 일정표"], "accent": "red", "column": "right", "flex": 1 },
      { "num": "V", "title": "지원부문", "pages": "45-49p", "items": ["안전관리 계획", "재난 및 응급 대응", "보험 가입 계획", "안전보건 관리비용"], "accent": "red", "column": "right", "flex": 1 },
      { "num": "VI", "title": "기타사항", "pages": "50-53p", "items": ["예산 사용 계획", "제안의 차별화", "기대 효과"], "accent": "gray", "column": "right", "flex": 1 }
    ],
    "page_number": 2
  }
}
